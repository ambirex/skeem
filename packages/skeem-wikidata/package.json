{
  "name": "@skeems/wikidata",
  "version": "0.1.0",
  "description": "Wikidata read source for the skeem CLI.",
  "license": "MIT",
  "author": "Brent Doll <brent.doll@gmail.com>",
  "homepage": "https://github.com/ambirex/skeem#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ambirex/skeem.git",
    "directory": "packages/skeem-wikidata"
  },
  "bugs": {
    "url": "https://github.com/ambirex/skeem/issues"
  },
  "keywords": [
    "skeem",
    "wikidata",
    "read-source",
    "knowledge-graph"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  }
}
