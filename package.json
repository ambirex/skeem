{
  "name": "skeem-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @skeem/directus && npm run build -w @skeem/cli",
    "dev": "npm run dev --workspace @skeem/cli",
    "eval:run": "npm run build && node ./test/evals/run.mjs",
    "eval:nano-gpt:models": "node ./test/evals/providers/nano-gpt-models.mjs",
    "eval:provider:sample": "npm run build && node ./test/evals/run.mjs --case ./test/evals/cases/01-discovery-and-read.json --provider command --provider-command 'node ./test/evals/providers/sample-command-provider.mjs'",
    "eval:sample": "npm run build && node ./test/evals/run.mjs --case ./test/evals/cases/01-discovery-and-read.json --transcript ./test/evals/transcripts/01-discovery-and-read.sample.json",
    "smoke:directus": "npm run build && node ./test/smoke/directus-ls.mjs",
    "smoke:directus:ls": "npm run build && node ./test/smoke/directus-ls.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
